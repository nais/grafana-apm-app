#!/usr/bin/env bash
# Pre-commit hook: runs the full check+test+build pipeline via mise.
# Install with: git config core.hooksPath .githooks
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "🔍 Running mise run all (check + test + build)..."
exec "$SCRIPT_DIR/scripts/mise-run.sh" all
