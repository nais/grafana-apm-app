    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "description": "Suksess rate mot interne applikasjoner målt fra applikasjonen med OpenTelemetry Auto-Instrumentering. I noen tilfeller vil 404 bli talt som feil.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "links": [],
          "mappings": [],
          "max": 1,
          "min": 0,
          "noValue": "1",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#F2495C",
                "value": 0
              },
              {
                "color": "#EAB839",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 5,
      "links": [
        {
          "targetBlank": true,
          "title": "",
          "url": "https://grafana.nav.cloud.nais.io/d/ceefsy2evwcu8e/operasjonelt-intern-applikasjon?${env:queryparam}﻿&${apps:queryparam}"
        }
      ],
      "maxPerRow": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.2",
      "repeat": "apps",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "editorMode": "code",
          "expr": "(\n  (\n    (\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=\"$apps\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n    )\n    /\n    (\n      clamp_min(\n        sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=\"$apps\"}[$__rate_interval])) or vector(0),\n        1e-10\n      )\n    )\n  ) > 0\n) \n* \n(\n  (\n    sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=\"$apps\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n  )\n  /\n  (\n    clamp_min(\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=\"$apps\"}[$__rate_interval])) or vector(0),\n      1e-10\n    )\n  )\n) \nor\nvector(1)",
          "instant": false,
          "legendFormat": "$tjenester",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "$apps",
      "type": "stat"
    },
