            "uid": "${prometheus}"
          },
          "editorMode": "code",
          "expr": "(\n  (\n    (\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", server_address=\"$tjenester\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n      +\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", http_host=\"$tjenester:443\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n    )\n    /\n    (\n      clamp_min(\n        sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", server_address=\"$tjenester\"}[$__rate_interval])) or vector(0)\n        +\n        sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", http_host=\"$tjenester:443\"}[$__rate_interval])) or vector(0),\n        1e-10\n      )\n    )\n  ) > 0\n) \n* \n(\n  (\n    sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", server_address=\"$tjenester\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n    +\n    sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", http_host=\"$tjenester:443\", status_code=~\"STATUS_CODE_OK|STATUS_CODE_UNSET\"}[$__rate_interval])) or vector(0)\n  )\n  /\n  (\n    clamp_min(\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", server_address=\"$tjenester\"}[$__rate_interval])) or vector(0)\n      +\n      sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\", http_host=\"$tjenester:443\"}[$__rate_interval])) or vector(0),\n      1e-10\n    )\n  )\n) \nor\nvector(1)",
          "instant": false,
          "legendFormat": "$tjenester",
          "range": true,
          "refId": "A"
        }
      ],
