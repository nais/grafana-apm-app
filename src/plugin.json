{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Nais APM",
  "id": "nais-apm-app",
  "backend": true,
  "executable": "gpx_apm",
  "info": {
    "keywords": ["app", "observability", "apm", "otel", "opentelemetry"],
    "description": "Application Performance Monitoring powered by OpenTelemetry data from Mimir, Loki, and Tempo",
    "author": {
      "name": "Nais"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [
      {
        "name": "Service Inventory",
        "path": "img/screenshot-service-inventory.png"
      },
      {
        "name": "Service Overview",
        "path": "img/screenshot-service-overview.png"
      },
      {
        "name": "Server Endpoints",
        "path": "img/screenshot-service-server.png"
      },
      {
        "name": "Frontend Observability",
        "path": "img/screenshot-service-frontend.png"
      }
    ],
    "links": [
      { "name": "GitHub", "url": "https://github.com/nais/grafana-otel-plugin" },
      { "name": "Issues", "url": "https://github.com/nais/grafana-otel-plugin/issues" },
      { "name": "License", "url": "https://github.com/nais/grafana-otel-plugin/blob/main/LICENSE" }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Services",
      "path": "/a/%PLUGIN_ID%/services",
      "addToNav": true,
      "defaultNav": true,
      "role": "Viewer"
    },
    {
      "type": "page",
      "name": "Service Map",
      "path": "/a/%PLUGIN_ID%/service-map",
      "addToNav": true,
      "role": "Viewer"
    },
    {
      "type": "page",
      "name": "Dependencies",
      "path": "/a/%PLUGIN_ID%/dependencies",
      "addToNav": true,
      "role": "Viewer"
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.0.0",
    "plugins": []
  }
}
